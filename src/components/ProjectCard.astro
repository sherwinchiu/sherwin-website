---
import Icon from "./Icons.astro";

export interface Props {
  title: string;
  subtitle: string;
  description: string;
  tags: string[];
  accent: string;
  glyph: string;
  href?: string;
  image?: string;
  imagePosition?: string;
}

const {
  title,
  subtitle,
  description,
  tags,
  accent,
  glyph,
  href,
  image,
  imagePosition = "center",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const imageSrc = image ? `${base}${image}` : null;

const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  target={href ? "_blank" : undefined}
  rel={href ? "noopener noreferrer" : undefined}
  class:list={[
    "group flex flex-col rounded-xl border border-[var(--border)] bg-[var(--card)] overflow-hidden",
    href && "hover:border-[var(--foreground)]/40 transition-colors",
  ]}
>
  <div
    class:list={[
      "relative h-40 w-full flex items-center justify-center overflow-hidden",
      !imageSrc && "bg-gradient-to-br",
      !imageSrc && accent,
    ]}
  >
    {
      imageSrc ? (
        <img
          src={imageSrc}
          alt={title}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          style={`object-position: ${imagePosition}`}
        />
      ) : (
        <span class="text-4xl select-none">{glyph}</span>
      )
    }
    {
      href && (
        <span class="absolute top-3 right-3 rounded-full bg-black/50 text-white p-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
          <Icon name="external" />
        </span>
      )
    }
  </div>
  <div class="flex flex-col gap-2 p-5">
    <div>
      <h3 class="font-medium">{title}</h3>
      <p class="text-xs text-[var(--muted)] mt-0.5">{subtitle}</p>
    </div>
    <p class="text-sm text-[var(--muted)] leading-relaxed">{description}</p>
    <div class="flex flex-wrap gap-1.5 pt-2">
      {
        tags.map((t) => (
          <span class="text-[10px] uppercase tracking-wider rounded-full bg-black/[.04] dark:bg-white/[.06] px-2 py-1 text-[var(--muted)]">
            {t}
          </span>
        ))
      }
    </div>
  </div>
</Tag>
